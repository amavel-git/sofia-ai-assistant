    "polygraph_process": {
      "enabled": true,
      "mode": "reusable_block",
      "block_id": 1718,
      "pattern_name": "SOFIA – Polygraph Process – Spain"
    },
    "city_services": {
      "enabled": true,
      "mode": "reusable_block",
      "block_id": 1722,
      "pattern_name": "SOFIA – City Services – Spain",
      "legacy_replaced_by": "city_services_grid"
    },
    "city_services_grid": {
      "enabled": true,
      "mode": "reusable_block",
      "block_id": 1813,
      "pattern_name": "SOFIA – City Services Grid – Spain",
      "description": "Grid with links to main Spanish city service pages."
    },
    "whatsapp_cta": {
      "enabled": true,
      "mode": "reusable_block",
      "block_id": 1876,
      "pattern_name": "SOFIA – WhatsApp CTA – Spain",
      "description": "Preferred WhatsApp contact CTA for Polígrafo España."
    }
  },
