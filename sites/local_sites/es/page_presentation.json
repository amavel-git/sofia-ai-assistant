{
  "version": "1.0",
  "workspace_id": "local.es",
  "purpose": "Spain-specific presentation preferences for Sofia-generated WordPress content. This file controls local CTA strategy, reusable Gutenberg blocks, FAQ format, trust blocks, and presentation choices. It must not define page structure or drafting content.",
  "rules": {
    "presentation_only": true,
    "no_page_structure": true,
    "no_finished_article_copy": true,
    "no_competitor_content": true
  },
  "wordpress": {
    "cms": "wordpress",
    "editor": "gutenberg",
    "language": "es",
    "country": "Spain",
    "domain": "https://poligrafoespana.com"
  },
  "faq": {
    "enabled": true,
    "mode": "yoast_faq_block",
    "match_headings": [
      "Preguntas Frecuentes",
      "Preguntas frecuentes"
    ]
  },
  "cta_strategy": {
    "enabled": true,
    "default_tone": "confidential, professional, calm",
    "avoid": [
      "pressure",
      "guarantees",
      "urgent manipulation",
      "absolute claims"
    ],
    "primary_cta_type": "whatsapp",
    "future_reusable_block_key": null
  },
  "gutenberg_reusable_blocks": {
    "enabled": false,
    "notes": "Block references will be added later after Spain-specific WordPress reusable blocks are created.",
    "blocks": {
      "primary_cta": null,
      "secondary_cta": null,
      "faq": null,
      "trust": null,
      "related_services": null,
      "strategic_links": null,
      "contact": null
    }
  },
  "trust_blocks": {
    "enabled": true,
    "preferred_themes": [
      "confidentiality",
      "professional process",
      "voluntary participation",
      "ethical limits",
      "international experience"
    ]
  },
  "strategic_links": {
    "enabled": true,
    "max_links_per_section": 5,
    "avoid_repeating_same_anchor": true
  },
  "layout_preferences": {
    "use_h1_once": true,
    "prefer_h2_for_main_sections": true,
    "prefer_h3_for_faq_questions": true,
    "avoid_excessive_short_sections": true
  },
  "image_strategy": {
    "enabled": true,
    "featured_image_required_by_default": true,
    "hero_image_required_by_default": true,
    "inline_images_enabled": true,
    "preferred_style": "realistic professional consultation",
    "preferred_subjects": [
      "professional consultation",
      "pre-test interview",
      "examiner speaking calmly with client",
      "modern Spanish office",
      "confidential professional meeting"
    ],
    "avoid": [
      "interrogation imagery",
      "police custody",
      "fear-based visuals",
      "aggressive suspect imagery",
      "unrealistic polygraph equipment",
      "medical diagnosis imagery"
    ],
    "future_generator": "flux",
    "wordpress_insertion": {
      "featured_image": true,
      "hero_inline": true,
      "inline_images": true
    }
  },
  "rendering": {
    "faq_format": "standard_html",
    "future_preferred_faq_format": "yoast_faq_block",
    "cta_rendering": "inline_html_now_reusable_block_later",
    "trust_rendering": "inline_html_now_reusable_block_later",
    "related_links_rendering": "inline_html_now_reusable_block_later",
    "image_rendering": "wordpress_media_or_generated_asset_later",
    "gutenberg_blocks_enabled": false
  },
  "validation_preferences": {
    "respect_blueprint_validation_requirements": true,
    "fail_on_missing_required_sections": true,
    "fail_on_missing_cta_when_required": true,
    "fail_on_missing_faq_when_required": true,
    "warn_on_missing_image_assets": true,
    "warn_on_missing_reusable_blocks": true
  },
  "gutenberg_blocks": {
    "contact_cta": {
      "enabled": true,
      "mode": "reusable_block",
      "block_id": 1690,
      "pattern_name": "SOFIA – Contact CTA – Spain",
      "match_headings": [
        "Solicite Información",
        "Solicite información"
      ],
      "legacy": true,
      "replaced_by": "whatsapp_cta"
    },
    "trust": {
      "enabled": true,
      "mode": "reusable_block",
      "block_id": 1699,
      "pattern_name": "SOFIA – Trust Block – Spain",
      "match_headings": [
        "Información Profesional",
        "Información profesional"
      ]
    },
    "examiner_experience": {
      "enabled": true,
      "mode": "reusable_block",
      "block_id": 1713,
      "pattern_name": "SOFIA – Examiner Experience – Spain"
    },
    "examiner_directory": {
      "enabled": true,
      "mode": "reusable_block",
      "block_id": 1702,
      "pattern_name": "SOFIA – About Examiner – Spain"
